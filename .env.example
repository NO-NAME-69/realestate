# ═══════════════════════════════════════════════════════════
# RP Investments — Production Environment Variables
# Copy this file to .env and fill in real values
# ═══════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────
DB_USER=rp_user
DB_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
DB_NAME=rp_module

# ── Security ──────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_minimum_64_characters_long_secret_for_jwt_operations
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
ENCRYPTION_KEY=CHANGE_THIS_to_64_hex_characters_for_aes256_encryption_key_here

# ── Razorpay Payment Gateway ─────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ── Frontend URL (for CORS) ──────────────────────────────
FRONTEND_URL=http://your-domain.com

# ── Business Configuration ───────────────────────────────
COMPANY_PROFIT_PCT=30
MIN_INVESTMENT_PAISE=100000
ACTIVATION_THRESHOLD_PAISE=5000000
MIN_TEAM_SIZE=20
REFERRAL_BONUS_PAISE=50000
